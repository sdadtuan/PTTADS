# KPI Finance — cảnh báo Slack/email + đồng bộ inbox CRM (systemd oneshot + timer)
#
# Trên VPS:
#   sudo cp scripts/ptt_finance_kpi_alert_cron.sh /var/www/ptt/scripts/
#   sudo chmod +x /var/www/ptt/scripts/ptt_finance_kpi_alert_cron.sh
#   sudo cp ptt-finance-kpi-alert.service ptt-finance-kpi-alert.timer /etc/systemd/system/
#   # .env gợi ý:
#   #   CRM_FINANCE_KPI_CRON_SECRET=...
#   #   PTT_FINANCE_KPI_SLACK_WEBHOOK=...     (tuỳ chọn)
#   #   PTT_FINANCE_KPI_ALERT_EMAIL=...       (tuỳ chọn)
#   #   PTT_FINANCE_KPI_ALERT_ONLY_CRITICAL=1
#   sudo systemctl daemon-reload
#   sudo systemctl enable --now ptt-finance-kpi-alert.timer
#   sudo systemctl start ptt-finance-kpi-alert.service
#   journalctl -u ptt-finance-kpi-alert.service -n 20 --no-pager

[Unit]
Description=PTT — cảnh báo KPI finance (một lần)
After=network.target ptt.service
Wants=ptt.service

[Service]
Type=oneshot
User=deploy
Group=www-data
Environment=PTT_APP_DIR=/var/www/ptt
Environment=PTT_GUNICORN_PORT=8002
EnvironmentFile=-/var/www/ptt/.env
ExecStart=/var/www/ptt/scripts/ptt_finance_kpi_alert_cron.sh

[Install]
WantedBy=multi-user.target
