# PTT Advertising Solutions — mẫu cấu hình (.env)
# Sao chép thành .env và điền giá trị thật. Không commit .env lên git.

PORT=5050

# Đăng nhập /admin, /cms, /crm
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
PTT_PRESALES_ON_LEAD=1

# Cookie session Flask (chuỗi ngẫu nhiên khi production)
SECRET_KEY=change-me-to-random-string
FLASK_SECRET_KEY=change-me-to-random-string

# OpenAI — chatbox CMS + trợ lý AI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
PTT_PRESALES_COST_CAP_VND=3000000
PTT_PRESALES_CAP_STRICT=1
PTT_AM_LIFECYCLE_CAPACITY=8
PTT_SP_LIFECYCLE_CAPACITY=12

# Finance KPI alerts (Business Dashboard + cron)
CRM_FINANCE_KPI_CRON_SECRET=
PTT_FINANCE_KPI_SLACK_WEBHOOK=
PTT_FINANCE_KPI_ALERT_EMAIL=
PTT_FINANCE_KPI_ALERT_ONLY_CRITICAL=1
PTT_PUBLIC_BASE_URL=https://your-domain.example

# Ngưỡng KPI (fallback khi chưa lưu DB) — xem crm_svc_finance_kpi.py
# PTT_KPI_ALERT_TOP2_WARN_PCT=50
# PTT_KPI_ALERT_AR_OVERDUE_CRITICAL_VND=50000000

# Dashboard tuần chủ DN — target RAG (fallback DB owner_*)
# PTT_OWNER_WEEKLY_CASH_SAFE_MIN_VND=50000000
# PTT_OWNER_WEEKLY_CASH_FORECAST_MIN_VND=0
# PTT_OWNER_WEEKLY_AR_OVERDUE_MAX_VND=30000000
# PTT_OWNER_WEEKLY_LEAD_NEW_TARGET=5
# PTT_OWNER_WEEKLY_CHURN_MAX_PCT=10

# Cron cảnh báo tuần (Slack/email + inbox Hub)
# PTT_OWNER_WEEKLY_SLACK_WEBHOOK=
# PTT_OWNER_WEEKLY_ALERT_EMAIL=
# PTT_OWNER_WEEKLY_ALERT_ONLY_RED=0

# Email form landing (tùy chọn)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM=

# CRM — Facebook Lead Ads webhook
# Docs: docs/crm/huong-dan-nguon-lead-va-setup.md
# CRM_FACEBOOK_VERIFY_TOKEN=          # Meta webhook verify (subscribe leadgen)
# CRM_FACEBOOK_APP_SECRET=            # X-Hub-Signature-256
# CRM_FACEBOOK_PAGE_ACCESS_TOKEN=      # Graph API — lấy chi tiết leadgen
# CRM_FACEBOOK_WEBHOOK_URL=https://your-domain.vn/api/crm/integration/webhooks/facebook
# CRM_FACEBOOK_SYNC_SECRET=           # Bearer cho sync-cron (hoặc dùng MARKETING_INGEST_SECRET)

# CRM — Zalo OA / Zalo Ads webhook
# CRM_ZALO_WEBHOOK_SECRET=
# CRM_ZALO_WEBHOOK_URL=https://your-domain.vn/api/crm/integration/webhooks/zalo

# CRM — Marketing ingest API + Facebook sync cron
CRM_MARKETING_INGEST_SECRET=
# CRM_ATTENDANCE_DEVICE_KEY=
# CRM_KPI_ACCESS=full

# Agency platform — PostgreSQL job queue (Phase 1)
# docker compose up -d  →  postgres on localhost:5432
DATABASE_URL=postgresql://ptt:ptt_dev@127.0.0.1:5432/ptt_agency
PTT_JOBS_ENABLED=1
PTT_WEBHOOK_V1_ENQUEUE=1
PTT_JOBS_SYNC_FALLBACK=1
# PTT_JOBS_DISABLED=0
# PTT_SQLITE_PATH=ptt.db
# CRM_AGENCY_SLA_CRON_SECRET=
# PTT_AGENCY_SLA_ALERT_EMAIL=
# SLACK_WEBHOOK_URL=

# Meta token vault + refresh (Phase 2 M1)
# PTT_TOKEN_VAULT_KEY=                        # base64 url-safe 32-byte key for AES-GCM
# META_APP_ID=                                # or CRM_FACEBOOK_APP_ID
# META_APP_SECRET=                            # or CRM_FACEBOOK_APP_SECRET
# PTT_META_TOKEN_REFRESH=0                    # bật trên VPS + ptt-meta-token-refresh.timer
# PTT_META_TOKEN_REFRESH_STUB=0               # local dev — skip Graph OAuth
# PTT_META_TOKEN_REFRESH_WINDOW_DAYS=14       # refresh when expiry within N days
# PTT_META_TOKEN_ALERT_DAYS=7                 # inbox/email alert threshold
# PTT_AGENCY_TOKEN_ALERT_EMAIL=
# PTT_META_INSIGHTS_SYNC=0                    # bật trên VPS + ptt-meta-insights.timer (02:00 ICT)
# PTT_META_INSIGHTS_STUB=0

# Phase 2 shadow + Meta timers (systemd on VPS)
# PTT_LEAD_SHADOW_SYNC=0                      # bật trên VPS + ptt-lead-shadow-sync.timer (1 phút)
# PTT_WRITE_SOAK_LOG=.local-dev/write-soak-evidence.jsonl  # 48h prod gate evidence
# sudo cp ptt-lead-shadow-sync.* ptt-meta-insights.* ptt-meta-token-refresh.* ptt-write-soak.* /etc/systemd/system/
# sudo systemctl daemon-reload
# sudo systemctl enable --now ptt-lead-shadow-sync.timer ptt-meta-insights.timer ptt-meta-token-refresh.timer ptt-write-soak.timer

# Write cutover prod gates (Phase 2 W3/W7)
# ./scripts/ci_openapi_write_freeze.sh
# ./scripts/write_soak_record.sh
# ./scripts/write_cutover_prod_gates.sh

# P1 — LeadAssigned idempotency + RMQ E2E + rollback drill evidence
# ./scripts/apply_pg_ddl_v3_events_idempotency.sh
# ./scripts/lead_assigned_rmq_e2e.sh
# ./scripts/rollback_drill_record.py
# PTT_ROLLBACK_DRILL_REPORT=.local-dev/rollback-drill-evidence.json

# Phase 2 completion gates (staging + prod assistant)
# deploy/env.staging-phase2-gates.example
# ./scripts/staging_phase2_gate_pack.sh
# ./scripts/seed_write_soak_staging.sh          # staging validation only
# ./scripts/prod_write_cutover.sh               # dry-run preflight
# ./scripts/phase2_uat_gate.py
# docs/runbooks/phase2-uat-signoff.md
# docs/runbooks/meta-token-refresh.md
# docs/runbooks/meta-insights-replay.md
# docs/runbooks/sentry-phase2-dashboards.md

# Closed-loop pilot — 1 client token + pixel + map + insights → CPL tab (P0 #4)
# deploy/env.staging-closed-loop-pilot.example
# ./scripts/staging_closed_loop_pilot.sh --sync --client-code DEMO

# Meta CAPI pilot (Phase 2 M5 / P2)
# PTT_CAPI_ENABLED=0
# PTT_CAPI_STUB=0                         # local dev — skip Graph POST
# PTT_CAPI_PURCHASE_STUB=0                # Purchase event log-only stub
# PTT_CAPI_PILOT_CLIENTS=                 # comma UUIDs; empty = all configured clients
# PTT_CAPI_TEST_EVENT_CODE=               # Meta Test Events tool
# PTT_META_PIXEL_ID=                      # fallback pixel if not in channel account meta
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=development
# SENTRY_RELEASE=pttads@git-sha
# SENTRY_TRACES_SAMPLE_RATE=0
# PTT_JSON_LOGS=1                         # prod/staging auto; dev: 0 = plain logs
# deploy/env.observability.example
# docs/runbooks/sentry-phase2-dashboards.md
# PTT_SLA_CRON_INTERVAL_SEC=300

# RabbitMQ — optional event outbox publisher (Phase 1b)
# docker compose up -d  →  rabbitmq on localhost:5672 (management :15672)
# RABBITMQ_URL=amqp://ptt:ptt_dev@127.0.0.1:5672/
# PTT_EVENT_PUBLISH_RMQ=0
# pip install pika  (required when PTT_EVENT_PUBLISH_RMQ=1)

# NestJS CRM read API (Phase 1b Bước 3–7)
# CRM_API_PORT=3000
# PTT_CRM_INTERNAL_KEY=
# PTT_CRM_API_AUTH_DISABLED=1
# PTT_LEADS_READ_SOURCE=pg
# PTT_SQLITE_PATH=ptt.db

# Dual-run Flask vs Nest (Phase 1b Bước 4–7)
# Flask reads SQLite; Nest reads PG replica when PTT_LEADS_READ_SOURCE=pg
# PTT_LEADS_API_DUAL_RUN=0
# PTT_NEST_LEADS_URL=http://127.0.0.1:3000
# PTT_DUAL_RUN_TIMEOUT_SEC=2.0
# PTT_DUAL_RUN_ASYNC=1

# Lead replica sync SQLite → PG (Phase 1b Bước 6)
# PTT_LEAD_REPLICA_SYNC=1
# CRM_AGENCY_LEAD_SYNC_CRON_SECRET=

# Migration Sprint 0 — queue-only webhooks + FB autosync daemon + PG ingest
# deploy/env.sprint0-migration.example + docs/runbooks/migration-sprint-0-prod.md
# PTT_JOBS_SYNC_FALLBACK=0
# CRM_FACEBOOK_BACKGROUND_IN_GUNICORN=0
# PTT_LEADS_WRITE_SOURCE=sqlite          # pg after staging soak (worker write_source=worker)
# PTT_WEBHOOKS_NEST_ENABLED=1
# PTT_WEBHOOKS_NEST_META=1
# PTT_WEBHOOKS_NEST_ZALO=1
# PTT_WEBHOOKS_NEST_GOOGLE=1
# CRM_GOOGLE_LEAD_WEBHOOK_KEY=
# PTT_WEBHOOKS_FLASK_FALLBACK=0
# python3 scripts/reconcile_sqlite_pg_leads.py
# python3 scripts/check_flask_route_freeze.py
# sudo ./scripts/apply_webhooks_upstream.sh nest-meta

# Hub campaigns → PG hub_campaign_map (Phase 2 P0)
# CRM_AGENCY_HUB_MAP_CRON_SECRET=          # optional; protects POST /api/crm/campaigns/sync-hub-map-all
# ./scripts/sync_hub_campaign_map.sh       # bulk seed from SQLite (after apply_pg_ddl_v3)

# Read upstream cutover (Phase 1b Bước 8)
# PTT_LEADS_READ_UPSTREAM=flask

# Write staging only (Phase 1b Bước 9) — NEVER enable on production yet
# PTT_LEADS_WRITE_ENABLED=0
# Staging pilot (Phase 2 P0 #3): deploy/env.staging-write-pilot.example
# ./scripts/staging_write_cutover_pilot.sh [--apply-sync-mode] [--drill]

# Production HTTPS
# SESSION_COOKIE_SECURE=1

# Phase 4 — Flask sunset + Meta campaign write + ClickHouse
# PTT_FLASK_MONOLITH_MODE=active          # active | readonly | retired
# PTT_META_CAMPAIGN_WRITE_STUB=1          # dev; prod pilot: 0
# PTT_META_CAMPAIGN_WRITE_PILOT=1         # gate real Meta API to pilot lists
# PTT_META_CAMPAIGN_WRITE_PILOT_CLIENTS=  # comma UUIDs
# PTT_META_CAMPAIGN_WRITE_PILOT_CAMPAIGNS=# comma Meta campaign IDs
# CLICKHOUSE_URL=http://127.0.0.1:8123
# CLICKHOUSE_USER=ptt
# CLICKHOUSE_PASSWORD=ptt_dev
# ./scripts/clickhouse_export_e2e.sh
# ./scripts/close_phase4_prod_cutover.sh
# deploy/env.phase4-prod.example

# SEO/AEO Phase 5 — Governance, Experimentation, Portal SEO
# Prod-safe defaults: governance ON; portal + experiments OFF until staged cutover.
# SEO_AEO_DB=pg
# PTT_SEO_GOVERNANCE_ENABLED=1          # prod default
# PTT_SEO_EXPERIMENTS_ENABLED=0         # enable after internal UAT (local dev: 1)
# PTT_SEO_CRON_SECRET=                   # Bearer token for /api/v1/seo/cron/* (VPS crontab)
# PTT_SEO_CRON_BASE_URL=                 # optional — cron scripts call HTTP instead of Python
# PTT_SEO_CRON_ALLOW_LOCAL=1             # allow localhost cron without secret
# PTT_SEO_SLACK_WEBHOOK=https://hooks.slack.com/services/...  # critical issue + report fail (P3e)
# PTT_SEO_TECH_AUTO_TASK=1
# PTT_SEO_TECH_AUTO_TASK_SEVERITIES=critical,high
# docs/runbooks/seo-aeo-cron.md
# PTT_PORTAL_SEO_ENABLED=0              # enable after portal pilot UAT (local: see local_crm_api_up.sh)
# PTT_PORTAL_SEO_SERVICE_TOKEN=          # legacy Flask internal; portal SEO now Nest PG native

# Phase 5 — Flask monolith retirement (stop ptt.service):
#   deploy/env.phase5-flask-retire.example
#   ./scripts/staging_phase5_gate_pack.sh
#   sudo -E APPLY=1 ./scripts/close_flask_retirement.sh
#   docs/runbooks/phase5-flask-retirement-checklist.md

