# Meta long-lived token refresh + expiry alerts (Phase 2 M1-03)
#
# VPS:
#   sudo cp ptt-meta-token-refresh.service ptt-meta-token-refresh.timer /etc/systemd/system/
#   # .env: PTT_META_TOKEN_REFRESH=1, META_APP_ID/SECRET, PTT_TOKEN_VAULT_KEY=...
#   sudo systemctl daemon-reload
#   sudo systemctl enable --now ptt-meta-token-refresh.timer
#   sudo systemctl start ptt-meta-token-refresh.service
#   journalctl -u ptt-meta-token-refresh.service -n 30 --no-pager

[Unit]
Description=PTT — Meta token refresh + alerts (một lần)
After=network.target ptt.service
Wants=ptt.service

[Service]
Type=oneshot
User=deploy
Group=www-data
Environment=PTT_APP_DIR=/var/www/ptt
Environment=PTT_META_TOKEN_REFRESH=1
EnvironmentFile=-/var/www/ptt/.env
ExecStart=/var/www/ptt/scripts/sync_meta_token_refresh.sh

[Install]
WantedBy=multi-user.target
