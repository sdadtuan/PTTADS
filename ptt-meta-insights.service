# Meta Marketing API → daily_performance (Phase 2 M2)
#
# VPS:
#   sudo cp ptt-meta-insights.service ptt-meta-insights.timer /etc/systemd/system/
#   # .env: PTT_META_INSIGHTS_SYNC=1, PTT_TOKEN_VAULT_KEY=..., hub_campaign_map seeded
#   sudo systemctl daemon-reload
#   sudo systemctl enable --now ptt-meta-insights.timer
#   sudo systemctl start ptt-meta-insights.service
#   journalctl -u ptt-meta-insights.service -n 30 --no-pager

[Unit]
Description=PTT — Meta insights sync (một lần)
After=network.target ptt.service
Wants=ptt.service

[Service]
Type=oneshot
User=deploy
Group=www-data
Environment=PTT_APP_DIR=/var/www/ptt
Environment=PTT_META_INSIGHTS_SYNC=1
EnvironmentFile=-/var/www/ptt/.env
ExecStart=/var/www/ptt/scripts/sync_meta_insights.sh

[Install]
WantedBy=multi-user.target
