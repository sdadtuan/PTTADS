# Phase 2 — Agency ops-web + write cutover + Meta closed-loop
# Parent: docs/SPEC_MIGRATION_FLASK_EXECUTION_PLAN.md §7
# Apply Phase 1 vars first, then overlay Phase 2 below.

export DATABASE_URL=postgresql://ptt:CHANGE_ME@127.0.0.1:5432/ptt_agency
export PTT_SQLITE_PATH=/var/www/ptt/ptt.db

# PG primary leads (Phase 1)
export PTT_LEADS_WRITE_SOURCE=pg
export PTT_LEADS_READ_SOURCE=pg
export PTT_LEAD_REPLICA_SYNC=0
export PTT_LEADS_WRITE_ENABLED=1
export PTT_LEADS_READ_UPSTREAM=nest
export PTT_LEADS_WRITE_UPSTREAM=nest
export PTT_NEST_LEADS_URL=http://127.0.0.1:3000
export PTT_CRM_INTERNAL_KEY=change-me-phase2-internal

# Track W — shadow rollback safety
export PTT_LEAD_SHADOW_SYNC=1

# Ingest rules (facebook config, assign, catalog) — PG snapshot, no ptt.db reads on worker
export PTT_LEAD_INGEST_RULES_SOURCE=pg

# Webhooks + worker
export PTT_JOBS_ENABLED=1
export PTT_WEBHOOK_V1_ENQUEUE=1
export PTT_WEBHOOKS_NEST_ENABLED=1
export PTT_WEBHOOKS_NEST_META=1
export PTT_WEBHOOKS_FLASK_FALLBACK=0
export CRM_FACEBOOK_BACKGROUND_IN_GUNICORN=0

# Staff / ops-web
export PTT_STAFF_JWT_SECRET=change-me-staff-jwt-min-32-chars
export PTT_OPS_CORS_ORIGINS=https://ops.pttads.vn,http://127.0.0.1:3200
export PTT_AGENCY_OPS_UPSTREAM=ops-web
export PTT_OPS_WEB_URL=https://ops.pttads.vn

# Track M — Meta closed-loop
export PTT_META_INSIGHTS_SYNC=1
export PTT_META_INSIGHTS_STUB=0
export PTT_META_TOKEN_REFRESH=1
export PTT_TOKEN_VAULT_KEY=change-me-32-byte-vault-key-min-len

# Cutover: sudo ./scripts/apply_phase2_cutover.sh --reload
