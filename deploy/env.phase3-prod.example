# Phase 3 prod cutover — portal.pttads.vn (Portal + API same-origin)
# Copy into /var/www/ptt/.env (merge with Phase 2 vars), then:
#   sudo -E APPLY=1 PORTAL_PILOT_PASSWORD='...' ./scripts/close_phase3_prod_cutover.sh

# ── Portal (Next.js) + Nest API qua cùng domain ──
# Nginx: deploy/nginx-portal.conf — / → :3100, /api/ + /health → :3000
NEXT_PUBLIC_PTT_API_URL=https://portal.pttads.vn
PORTAL_PORT=3100
PTT_PORTAL_JWT_SECRET=CHANGE_ME_MIN_32_CHARS_RANDOM
PTT_PORTAL_AUTH_MODE=dual
PTT_PORTAL_REFRESH_TTL_SEC=2592000
PTT_PORTAL_EMAIL_NOTIFY=1
# PTT_PORTAL_EMAIL_WEBHOOK_URL=https://hooks.example.com/portal-email
PTT_PORTAL_ALLOW_STUB=0
PTT_PORTAL_STUB_USERS=
PTT_PORTAL_CORS_ORIGINS=https://portal.pttads.vn
PTT_CRM_INTERNAL_KEY=CHANGE_ME_S2S_INTERNAL

# Pilot portal users seeded via seed_portal_pilot_users.py (scrypt)
# PORTAL_PILOT_PASSWORD=set-at-cutover-time-only

# ── Temporal ──
PTT_TEMPORAL_ADDRESS=127.0.0.1:7233
PTT_TEMPORAL_NAMESPACE=default
PTT_TEMPORAL_TASK_QUEUE=ptt-agency

# ── Google insights (optional pilot) ──
PTT_GOOGLE_INSIGHTS_SYNC=1
# PTT_GOOGLE_ADS_REFRESH_TOKEN=...

# ── Portal SEO (Nest PG native — Flask proxy not required) ──
PTT_PORTAL_SEO_ENABLED=1
PTT_SEO_GOVERNANCE_ENABLED=1
# UAT gate: ./scripts/phase3_prod_uat_gate.sh (Nest + portal-web up)

# ── Hub PG migration (staging soak before prod primary) ──
PTT_HUB_READ_SOURCE=1
PTT_SOP_READ_SOURCE=1
# PTT_HUB_PG_PRIMARY=1   # enable after 7d staging soak
PTT_SQLITE_PATH=/var/www/ptt/ptt.db

# Lead shadow — keep ON until Phase 2 write soak ≥30d
PTT_LEAD_SHADOW_SYNC=1

# ── Observability ──
# NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
# SENTRY_DSN=https://...@sentry.io/...
