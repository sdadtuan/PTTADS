# Meta Enterprise B14 — Warehouse BI (ClickHouse + Grafana + compliance API)
# Requires daily_performance (DDL v3+) and ClickHouse docker stack.

PTT_META_WAREHOUSE_EXPORT=0
PTT_META_INSIGHTS_HOURLY=0
# Comma-separated client UUIDs when hourly sync enabled (Tier B high-spend accounts)
PTT_META_INSIGHTS_HOURLY_CLIENTS=

# ClickHouse (reuse Phase 4 stack)
# CLICKHOUSE_URL=http://127.0.0.1:8123
# CLICKHOUSE_USER=ptt
# CLICKHOUSE_PASSWORD=ptt_dev

# Apply ClickHouse schema before first export:
# ./scripts/clickhouse_init.sh  (or ensure_meta_facts_schema via export script)

# Grafana: import deploy/grafana/meta-ops-dashboard.json

# Nest APIs (staff-only):
# GET /api/v1/meta/compliance/export?client_id=
# GET /api/v1/metrics/cross-channel/summary?days=7&client_id=
