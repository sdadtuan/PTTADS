# Staging Phase 2 gate pack — 3 clients + write + soak + UAT
# source before ./scripts/staging_phase2_gate_pack.sh

export DATABASE_URL=postgresql://ptt:ptt_dev@127.0.0.1:5432/ptt_agency
export PTT_SQLITE_PATH=/var/www/ptt/ptt.db
export PTT_NEST_LEADS_URL=http://127.0.0.1:3000
export PTT_CRM_API_AUTH_DISABLED=1

# Write cutover flags
export PTT_LEADS_WRITE_ENABLED=1
export PTT_LEADS_WRITE_UPSTREAM=nest
export PTT_LEAD_SHADOW_SYNC=1
export PTT_LEADS_READ_UPSTREAM=nest
export PTT_LEAD_REPLICA_SYNC=0

# Closed-loop — ≥3 pilot clients (comma-separated codes)
export PTT_CLOSED_LOOP_CLIENT_CODES=DEMO,CLIENT_B,CLIENT_C
export PTT_CLOSED_LOOP_MIN_CLIENTS=3

# Meta insights (stub OK on staging without Graph)
export PTT_META_INSIGHTS_SYNC=1
export PTT_META_INSIGHTS_STUB=1
export PTT_TOKEN_VAULT_KEY=

# 48h soak log path
export PTT_WRITE_SOAK_LOG=.local-dev/write-soak-evidence.jsonl

# Optional CAPI / RMQ E2E
# export PTT_EVENT_PUBLISH_RMQ=1
# export PTT_CAPI_STUB=1

# Per-client setup (repeat for each code):
#   ./scripts/seed_meta_channel_account.py  # CLIENT_CODE=...
#   ./scripts/sync_hub_campaign_map.sh
