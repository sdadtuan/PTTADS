# Meta Enterprise B8 — measurement parity (staging / pilot)
# Copy relevant lines to deploy env after DDL v4 meta enterprise applied.

# Alerts engine (default off — widen after soak)
PTT_META_ALERTS_ENABLED=0

# CPL high threshold = target × (1 + pct/100); default 15%
PTT_META_ALERT_CPL_PCT=15

# Unmapped spend alert when unmapped spend / total spend exceeds this pct
PTT_META_ALERT_UNMAPPED_SPEND_PCT=15
