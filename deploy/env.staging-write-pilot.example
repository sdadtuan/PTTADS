# Staging write cutover pilot — source before ./scripts/staging_write_cutover_pilot.sh
# NEVER use on production until change window (runbook §4)

export DATABASE_URL=postgresql://ptt:ptt_dev@127.0.0.1:5432/ptt_agency
export PTT_SQLITE_PATH=/var/www/ptt/ptt.db

# Read (prerequisite B8)
export PTT_LEADS_READ_UPSTREAM=nest
export PTT_LEADS_READ_SOURCE=pg
export PTT_NEST_LEADS_URL=http://127.0.0.1:3000
export PTT_CRM_INTERNAL_KEY=change-me-staging-shared-secret
export PTT_CRM_API_AUTH_DISABLED=1

# Write pilot (Phase 2 P0 #3)
export PTT_LEADS_WRITE_ENABLED=1
export PTT_LEADS_WRITE_UPSTREAM=nest
export PTT_LEAD_SHADOW_SYNC=1
export PTT_LEAD_REPLICA_SYNC=0

# Jobs / closed-loop (optional on same staging host)
export PTT_META_INSIGHTS_SYNC=1
export PTT_META_TOKEN_REFRESH=1

# After pilot preflight:
#   psql "$DATABASE_URL" -c "UPDATE crm_leads_sync_state SET sync_mode='pg_primary', updated_at=NOW() WHERE id=1;"
# Or: ./scripts/staging_write_cutover_pilot.sh --apply-sync-mode
