# Meta Enterprise B10 — Intelligence (anomaly, ROAS, budget recommend)
# Requires B8 DDL v4 (meta_alerts) + daily_performance with conversion_value.

# Anomaly median spike eval + API/UI
PTT_META_ANOMALY_ENABLED=0
NEXT_PUBLIC_PTT_META_ANOMALY_ENABLED=0
PTT_META_ANOMALY_SPIKE_PCT=50
PTT_META_ANOMALY_WINDOW_DAYS=7

# ROAS series API + portal (hide when stub)
PTT_META_ROAS_ENABLED=0
NEXT_PUBLIC_PTT_META_ROAS_ENABLED=0
PTT_META_ROAS_MIN_TARGET=3
PTT_META_ROAS_MIN_SPEND_VND=500000

# Budget recommend heuristics (read-only)
PTT_META_BUDGET_RECOMMEND_DECREASE_PCT=15
PTT_META_BUDGET_RECOMMEND_INCREASE_PCT=10
PTT_META_BUDGET_RECOMMEND_CPL_OVER=1.15
PTT_META_BUDGET_RECOMMEND_CPL_UNDER=0.85

# Adset/ad insight granularity (apply DDL v6 first)
PTT_META_INSIGHTS_LEVEL=campaign

# Tier A (optional — separate flags)
PTT_META_BUDGET_PACING_ENABLED=0
PTT_META_CLIENT_REPORT_WEEKLY=0

# B8 alerts should remain on for persisted anomaly rows in meta_alerts
PTT_META_ALERTS_ENABLED=0

# Recommended: enable B10 only after B9 CAPI soak >= 30d
# See docs/runbooks/b9-tracking-pilot-soak.md
