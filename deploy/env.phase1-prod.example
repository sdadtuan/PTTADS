# Phase 1 — PostgreSQL primary for leads (no ptt.db OLTP)
# Parent: docs/SPEC_MIGRATION_FLASK_EXECUTION_PLAN.md §6
# source: sudo set -a && source deploy/env.phase1-prod.example && set +a

export DATABASE_URL=postgresql://ptt:CHANGE_ME@127.0.0.1:5432/ptt_agency
export PTT_SQLITE_PATH=/var/www/ptt/ptt.db

# --- Lead OLTP: PG primary ---
export PTT_LEADS_WRITE_SOURCE=pg
export PTT_LEADS_READ_SOURCE=pg
export PTT_LEAD_REPLICA_SYNC=0
export PTT_LEAD_SHADOW_SYNC=0

# Nest read/write (staff JWT + internal key)
export PTT_LEADS_WRITE_ENABLED=1
export PTT_LEADS_READ_UPSTREAM=nest
export PTT_LEADS_WRITE_UPSTREAM=nest
export PTT_NEST_LEADS_URL=http://127.0.0.1:3000
export PTT_CRM_INTERNAL_KEY=change-me-phase1-internal

# Staff auth (ops-web)
export PTT_STAFF_JWT_SECRET=change-me-staff-jwt-min-32-chars
export PTT_OPS_CORS_ORIGINS=https://ops.pttads.vn,http://127.0.0.1:3200

# Webhooks + worker queue (all v1 → Nest)
export PTT_JOBS_ENABLED=1
export PTT_WEBHOOK_V1_ENQUEUE=1
export PTT_WEBHOOKS_NEST_ENABLED=1
export PTT_WEBHOOKS_NEST_META=1
export PTT_WEBHOOKS_FLASK_FALLBACK=0

# FB autosync outside Gunicorn
export CRM_FACEBOOK_BACKGROUND=1
export CRM_FACEBOOK_BACKGROUND_IN_GUNICORN=0

# Flask monolith soak — read-only UI, lead writes blocked (503 leads_pg_primary)
# export PTT_FLASK_MONOLITH_MODE=readonly

# Cutover nginx:
#   sudo ./scripts/apply_phase1_cutover.sh --reload
#
# Restart:
#   sudo systemctl restart ptt-crm-api ptt-worker ptt-fb-autosync ptt ops-web
