# Meta Enterprise B9 — Conversion OS / tracking (staging / pilot)
# Apply DDL first: ./scripts/apply_pg_ddl_v5_meta_conversion.sh
# Requires B8 DDL v4 (meta_alerts) already applied.

# Master CAPI dispatch (default off — pilot then widen)
PTT_CAPI_ENABLED=0
PTT_CAPI_STUB=0
# Comma-separated client UUIDs; empty = all clients when CAPI enabled
PTT_CAPI_PILOT_CLIENTS=

# Graph test events (Test pixel button in ops-web)
PTT_CAPI_TEST_EVENT_CODE=

# Nest + worker: conversion backfill job
PTT_META_CONVERSION_SYNC_ENABLED=0

# B9 tracking alerts (extends B8 meta_alerts_eval)
PTT_META_ALERT_CAPI_FAIL_RATE_PCT=10

# Weekly archive job (dry-run unless payload dry_run=false)
PTT_META_INSIGHTS_ARCHIVE_ENABLED=0
PTT_META_INSIGHTS_ARCHIVE_DIR=.local-dev/archive/meta-insights

# Nest guards + ops-web /meta/tracking nav
PTT_META_TRACKING_ENABLED=0
NEXT_PUBLIC_PTT_META_TRACKING_ENABLED=0

# Insights archive threshold (days); weekly job B9
PTT_META_INSIGHTS_RETENTION_DAYS=400

# Launch QA: require CAPI sent in 48h for launch_ready (strict mode)
PTT_LAUNCH_QA_META_STRICT=0

# B9 pilot soak (30d gate — see docs/runbooks/b9-tracking-pilot-soak.md)
PTT_B9_SOAK_DAYS=30
PTT_B9_SOAK_MIN_SAMPLES=28
PTT_B9_SOAK_MAX_FAIL_RATE_PCT=10
PTT_B9_SOAK_MIN_SENT_24H=1
# PTT_B9_SOAK_LOG=.local-dev/b9-tracking-soak-evidence.jsonl

# B8 alerts (keep off until B9 tracking soak complete)
PTT_META_ALERTS_ENABLED=0
