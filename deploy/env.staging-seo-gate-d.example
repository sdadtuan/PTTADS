# Staging — SEO Gate D timer (CWV stub, AEO schedule, crawl reminders)
# Merge vào /var/www/ptt/.env trên staging VPS:
#   grep -v '^#' deploy/env.staging-seo-gate-d.example >> .env
# Hoặc: set -a && source deploy/env.staging-seo-gate-d.example && set +a

# Cron auth (nếu dùng HTTP mode thay vì Python trực tiếp)
# PTT_SEO_CRON_SECRET=change-me-staging-gate-d
# PTT_SEO_CRON_BASE_URL=https://staging.pttads.vn

# Gate D — staging pilot (stub CWV, không cần PageSpeed key)
PTT_CWV_ENABLED=1
PTT_CWV_STUB=1
PTT_CWV_PER_CLIENT=2
PTT_CWV_MAX_CLIENTS=5

PTT_CRAWL_REMINDER_ENABLED=1
PTT_CRAWL_REMINDER_DAYS=30

PTT_AEO_SCHEDULE_ENABLED=1
PTT_AEO_AUTO_DRAFT_ENABLED=1
PTT_AEO_SCHEDULE_MAX_CLIENTS=5

# Optional Teams (song song Slack)
# PTT_SEO_TEAMS_WEBHOOK=https://outlook.office.com/webhook/...

# Prod staging: bật PageSpeed thật khi có key
# PTT_CWV_STUB=0
# PAGESPEED_API_KEY=...
