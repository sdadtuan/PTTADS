# Migration Sprint 0 — prod stability + PG lead write
# Parent: docs/runbooks/migration-sprint-0-prod.md
# source before: sudo set -a && source deploy/env.sprint0-migration.example && set +a

export DATABASE_URL=postgresql://ptt:CHANGE_ME@127.0.0.1:5432/ptt_agency
export PTT_SQLITE_PATH=/var/www/ptt/ptt.db

# Queue-only webhooks (S0-2)
export PTT_JOBS_ENABLED=1
export PTT_WEBHOOK_V1_ENQUEUE=1
export PTT_JOBS_SYNC_FALLBACK=0

# FB autosync outside Gunicorn (S0-3)
export CRM_FACEBOOK_BACKGROUND=1
export CRM_FACEBOOK_BACKGROUND_IN_GUNICORN=0

# PG-primary ingest after staging soak (S0-10) — default sqlite until cutover
# export PTT_LEADS_WRITE_SOURCE=pg
export PTT_LEADS_READ_SOURCE=pg
export PTT_LEAD_REPLICA_SYNC=1

# Nest read API
export PTT_NEST_LEADS_URL=http://127.0.0.1:3000
export PTT_CRM_INTERNAL_KEY=change-me-sprint0-migration

# Phase 0 ops-web staff-auth
export PTT_STAFF_JWT_SECRET=change-me-staff-jwt-min-32-chars
export PTT_STAFF_STUB_USERS=staff@demo.local:demo123:staff-demo-1:1:Demo Staff
export PTT_OPS_CORS_ORIGINS=https://ops.pttads.vn,http://127.0.0.1:3200

# Phase 0 webhooks (Nest meta native)
export PTT_WEBHOOKS_NEST_ENABLED=1
export PTT_WEBHOOKS_NEST_META=1
export PTT_WEBHOOKS_FLASK_FALLBACK=0

# Deploy:
#   sudo cp deploy/ptt-fb-autosync.service deploy/ptt-worker.service /etc/systemd/system/
#   sudo systemctl daemon-reload
#   sudo systemctl enable --now ptt-fb-autosync ptt-worker
#   sudo systemctl restart ptt
