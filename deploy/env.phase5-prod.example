# Phase 5 production — Governance, Portal SEO, Experimentation
# Copy vars into /var/www/ptt/.env then staged rollout via close_phase5_prod_cutover.sh

export SEO_AEO_DB=pg
export DATABASE_URL=postgresql://ptt:***@127.0.0.1:5432/ptt_agency

# Step 1 — governance publish gates (default ON after Phase 5 deploy)
export PTT_SEO_GOVERNANCE_ENABLED=1

# Step 2 — portal SEO (after pilot UAT + seed map)
export PTT_PORTAL_SEO_ENABLED=0
export PTT_PORTAL_SEO_SERVICE_TOKEN=          # shared secret Flask + Nest
export PTT_FLASK_MONOLITH_URL=http://127.0.0.1:8002

# Step 3 — experiments console (internal team first)
export PTT_SEO_EXPERIMENTS_ENABLED=0

# Enterprise backlog (entity graph, rank tracker, CMS publish, BI export)
export PTT_SEO_ENTERPRISE_ENABLED=1
# CMS webhook pilot (see docs/runbooks/seo-cms-webhook-pilot.md)
# export PTT_SEO_CMS_WEBHOOK_SECRET=<strong-secret>
# export PTT_SEO_CMS_PILOT_WEBHOOK_URL=https://rs.pttads.vn/api/v1/seo/internal/cms-webhook/receive
# CLICKHOUSE_URL=http://127.0.0.1:8123  # required for BI → ClickHouse export

# Pilot map (once per client):
# python3 scripts/seed_portal_seo_pilot_map.py --apply --client-id <UUID> --customer-id <CRM_ID>

# Gates:
# ./scripts/phase5_prod_cutover_gate.sh
# ./scripts/phase5_portal_seo_e2e_gate.sh   # before enabling portal

# Soak (daily cron ≥7 days after cutover):
# ./scripts/phase5_soak_record.sh
# PHASE5_SKIP_SOAK=0 ./scripts/phase5_prod_cutover_gate.sh

# Staged cutover:
# APPLY=1 PHASE5_ENABLE_GOVERNANCE=1 sudo -E ./scripts/close_phase5_prod_cutover.sh
# APPLY=1 PHASE5_ENABLE_PORTAL=1 PHASE5_SKIP_PORTAL_SIGNOFF=0 sudo -E ./scripts/close_phase5_prod_cutover.sh
# APPLY=1 PHASE5_ENABLE_EXPERIMENTS=1 sudo -E ./scripts/close_phase5_prod_cutover.sh
