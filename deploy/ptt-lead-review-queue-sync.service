[Unit]
Description=PTT CRM B2 review queue sync (Wave B4)
After=network-online.target ptt-crm-api.service
Wants=ptt-crm-api.service

[Service]
Type=oneshot
User=deploy
Group=www-data
Environment=PTT_APP_DIR=/var/www/ptt
EnvironmentFile=-/var/www/ptt/.env
ExecStart=/var/www/ptt/scripts/lead_review_queue_sync_cron.sh

[Install]
WantedBy=multi-user.target
