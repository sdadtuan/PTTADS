# Horizon 1 — Meta / Facebook Ads migration off Flask admin
# source deploy/env.horizon1-meta-ads.example

DATABASE_URL=postgresql://ptt:CHANGE_ME@127.0.0.1:5432/ptt_agency
PTT_ARTIFACTS_DIR=.local-dev
OPS_E2E_API_URL=http://127.0.0.1:3000
PTT_CRM_API_AUTH_DISABLED=1

# M1-B1 — Webhooks Nest-only (no Flask fallback)
PTT_WEBHOOKS_NEST_ENABLED=1
PTT_WEBHOOKS_NEST_META=1
PTT_WEBHOOKS_FLASK_FALLBACK=0

# M1-B2 — Autosync outside Gunicorn (Sprint 0)
CRM_FACEBOOK_BACKGROUND=1
CRM_FACEBOOK_BACKGROUND_IN_GUNICORN=0
# After decouple: PTT_FB_AUTOSYNC_PG=1

# M1-B3 — Hub admin on ops-web
PTT_FLASK_META_ADS_ADMIN_RETIRED=1
HORIZON1_EXPECT_META_HUB_RETIRED=1

# M1-B4 — Campaign write pilot (optional; set HORIZON1_EXPECT_CAMPAIGN_WRITE_PILOT=1 to gate)
# PTT_META_CAMPAIGN_WRITE_STUB=0
# PTT_META_CAMPAIGN_WRITE_PILOT=1
# PTT_META_CAMPAIGN_WRITE_PILOT_CLIENTS=
# PTT_META_CAMPAIGN_WRITE_PILOT_CAMPAIGNS=
# HORIZON1_EXPECT_CAMPAIGN_WRITE_PILOT=0

# M1-C — systemd: deploy/ptt-horizon1-meta-soak.timer + .service

# Gate expectations
HORIZON1_SKIP_NEST_SMOKE=0
HORIZON1_SKIP_BUILD=1
HORIZON1_SKIP_SOAK=0
PTT_HORIZON1_SOAK_DAYS=7
PTT_HORIZON1_SOAK_MIN_SAMPLES=7

# Pilot metrics export
# HORIZON1_PILOT_CLIENTS=uuid:Label
HORIZON1_METRICS_DAYS=28

# Staging soak bootstrap — NEVER on prod
# HORIZON1_BOOTSTRAP_SOAK=1
