# CRM Flask retirement — staged env (Wave 0 cutover flags)
# source deploy/env.crm-flask-migration.example

DATABASE_URL=postgresql://ptt:CHANGE_ME@127.0.0.1:5432/ptt_agency
PTT_ARTIFACTS_DIR=.local-dev
OPS_E2E_API_URL=http://127.0.0.1:3000

# Wave 0 — already migrated modules
PTT_LEADS_WRITE_SOURCE=pg
PTT_LEADS_READ_SOURCE=pg
PTT_LEAD_INGEST_RULES_SOURCE=pg
PTT_AGENCY_OPS_UPSTREAM=ops-web
PTT_AGENCY_FLASK_READONLY=1

# Horizon 0 + 1
PTT_FLASK_SEO_ADMIN_RETIRED=1
PTT_FLASK_EMAIL_ADMIN_RETIRED=1
PTT_FLASK_META_ADS_ADMIN_RETIRED=1
PTT_WEBHOOKS_NEST_ENABLED=1
PTT_WEBHOOKS_NEST_META=1
PTT_WEBHOOKS_NEST_ZALO=1
PTT_WEBHOOKS_NEST_GOOGLE=1
PTT_WEBHOOKS_FLASK_FALLBACK=0
CRM_FACEBOOK_BACKGROUND=1
CRM_FACEBOOK_BACKGROUND_IN_GUNICORN=0

# Gate expectations (informational until all modules migrated)
CRM_EXPECT_LEADS_NEST=1
CRM_EXPECT_DELIVERY_ADMIN_RETIRED=1
CRM_SKIP_PHASE5_PREREQ=1
CRM_FLASK_REQUIRE_FULL_MIGRATION=0
CRM_FLASK_MIN_MIGRATED_PCT=100

# Wave 1 — Catalog on ops-web + Nest
PTT_CRM_CATALOG_UPSTREAM=ops-web
PTT_FLASK_CRM_CATALOG_RETIRED=1
WAVE1_EXPECT_CATALOG_OPS_WEB=1

# Wave 1b — Leads legacy (activities, assign, audit) on Nest + ops-web
PTT_CRM_LEADS_LEGACY_UPSTREAM=nest
PTT_FLASK_CRM_LEADS_LEGACY_RETIRED=1
PTT_LEADS_WRITE_UPSTREAM=nest
WAVE1B_EXPECT_LEADS_LEGACY_NEST=1

# Wave 1 full — Flask /crm/leads UI retired → ops-web
PTT_CRM_LEADS_UPSTREAM=ops-web
PTT_FLASK_CRM_LEADS_UI_RETIRED=1
WAVE1F_EXPECT_LEADS_OPS_WEB=1

# Wave 2 — Customers + Intake on ops-web + Nest
PTT_CRM_CUSTOMERS_UPSTREAM=ops-web
PTT_FLASK_CRM_CUSTOMERS_RETIRED=1
PTT_CRM_INTAKE_UPSTREAM=ops-web
PTT_FLASK_CRM_INTAKE_RETIRED=1
WAVE2_EXPECT_CUSTOMERS_OPS_WEB=1
WAVE2_EXPECT_INTAKE_OPS_WEB=1

# Wave 2+ — Cases API on Nest
PTT_CRM_CASES_UPSTREAM=nest
PTT_FLASK_CRM_CASES_RETIRED=1
WAVE2P_EXPECT_CASES_NEST=1

# Wave 3 — Marketing plans + Service lifecycle + SOP on ops-web + Nest
PTT_CRM_MARKETING_PLANS_UPSTREAM=ops-web
PTT_FLASK_CRM_MARKETING_PLANS_RETIRED=1
PTT_CRM_SERVICE_LIFECYCLE_UPSTREAM=ops-web
PTT_FLASK_CRM_SERVICE_LIFECYCLE_RETIRED=1
PTT_CRM_SOP_UPSTREAM=ops-web
PTT_FLASK_CRM_SOP_RETIRED=1
WAVE3_EXPECT_OPS_WEB=1

# Wave 4 — Sales + KPI + Staff on ops-web + Nest
PTT_CRM_SALES_UPSTREAM=ops-web
PTT_FLASK_CRM_SALES_RETIRED=1
PTT_CRM_KPI_UPSTREAM=ops-web
PTT_FLASK_CRM_KPI_RETIRED=1
PTT_CRM_STAFF_UPSTREAM=ops-web
PTT_FLASK_CRM_STAFF_RETIRED=1
WAVE4_EXPECT_OPS_WEB=1

# Wave 4+ — Sales extended + Proposals + Payroll dashboard on Nest
PTT_CRM_PROPOSALS_UPSTREAM=ops-web
PTT_FLASK_CRM_PROPOSALS_RETIRED=1
PTT_CRM_PAYROLL_UPSTREAM=nest
PTT_FLASK_CRM_PAYROLL_RETIRED=1
WAVE4P_EXPECT_OPS_WEB=1

# Wave 5 — RE projects + Payroll full UI on ops-web + Nest
PTT_CRM_RE_PROJECTS_UPSTREAM=ops-web
PTT_FLASK_CRM_RE_PROJECTS_RETIRED=1
PTT_CRM_PAYROLL_UPSTREAM=ops-web
PTT_FLASK_CRM_PAYROLL_RETIRED=1
WAVE5_EXPECT_OPS_WEB=1

# Wave 5+ — RE accounting dashboard/cash-flow on Nest
PTT_CRM_RE_PROJECTS_ACCOUNTING_UPSTREAM=nest
PTT_FLASK_CRM_RE_PROJECTS_ACCOUNTING_RETIRED=1
WAVE5P_EXPECT_ACCOUNTING_NEST=1

# Wave 5++ — RE KPI/risks/budget on Nest
PTT_CRM_RE_PROJECTS_KPI_RISKS_UPSTREAM=nest
PTT_FLASK_CRM_RE_PROJECTS_KPI_RISKS_RETIRED=1
WAVE5PP_EXPECT_KPI_RISKS_NEST=1

# Wave 5+++ — RE staff/lead-config/workflow/export on Nest
PTT_CRM_RE_PROJECTS_OPS_UPSTREAM=nest
PTT_FLASK_CRM_RE_PROJECTS_OPS_RETIRED=1
WAVE5PPP_EXPECT_OPS_NEST=1

# Wave B5 S0 — Service delivery promote (Nest contract + GDKD approval)
PTT_CRM_SERVICE_DELIVERY_NEST=1
PTT_SOP_AUTO_START_ON_LAUNCH=1
PTT_SOP_OVERDUE_ESCALATE=1
PTT_CRM_LEADS_FUNNEL_NEST=1
PTT_PRESALES_ON_LEAD=1

# Wave 6 — Finance / owner-weekly on ops-web + Nest
PTT_CRM_FINANCE_UPSTREAM=ops-web
PTT_FLASK_CRM_FINANCE_RETIRED=1
WAVE6_EXPECT_FINANCE_NEST=1

# Wave 7 — CRM shell hub + svc-finance on Nest; Phase 5 readiness
PTT_CRM_SHELL_UPSTREAM=ops-web
PTT_FLASK_CRM_SHELL_RETIRED=1
WAVE7_EXPECT_SHELL_OPS_WEB=1
WAVE7_EXPECT_PHASE5_READY=1

# Phase 5 — ONLY when gap report can_stop_ptt_service=true
# PTT_FLASK_MONOLITH_MODE=retired

# Wave 8 — Flask HTTP removed from repo; Phase 5 complete
WAVE8_EXPECT_FLASK_REMOVED=1
PTT_NEST_API_URL=http://127.0.0.1:3000
CRM_FLASK_REQUIRE_FULL_MIGRATION=1
CRM_SKIP_PHASE5_PREREQ=0
PHASE5_FLASK_STOP_COMPLETE=1
