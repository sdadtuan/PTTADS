{
  "__inputs": [
    {
      "name": "DS_CLICKHOUSE",
      "label": "ClickHouse",
      "description": "grafana-clickhouse-datasource",
      "type": "datasource",
      "pluginId": "grafana-clickhouse-datasource",
      "pluginName": "ClickHouse"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "9.0.0" },
    { "type": "datasource", "id": "grafana-clickhouse-datasource", "name": "ClickHouse", "version": "4.0.0" }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "GSC clicks",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
      "targets": [
        {
          "refId": "A",
          "format": 1,
          "queryType": "sql",
          "rawSql": "SELECT\n  fact_date AS time,\n  sum(metric_value) AS clicks\nFROM ptt.seo_daily_facts\nWHERE metric_name = 'gsc_clicks'\n  AND customer_id = $customer_id\n  AND fact_date >= today() - toInt32($days)\nGROUP BY fact_date\nORDER BY fact_date"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 8 } },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "GSC impressions",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
      "targets": [
        {
          "refId": "A",
          "format": 1,
          "queryType": "sql",
          "rawSql": "SELECT\n  fact_date AS time,\n  sum(metric_value) AS impressions\nFROM ptt.seo_daily_facts\nWHERE metric_name = 'gsc_impressions'\n  AND customer_id = $customer_id\n  AND fact_date >= today() - toInt32($days)\nGROUP BY fact_date\nORDER BY fact_date"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 8 } },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Content published",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 8 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
      "targets": [
        {
          "refId": "A",
          "format": 1,
          "queryType": "sql",
          "rawSql": "SELECT sum(metric_value) AS value\nFROM ptt.seo_daily_facts\nWHERE metric_name = 'content_published'\n  AND customer_id = $customer_id\n  AND fact_date = (SELECT max(fact_date) FROM ptt.seo_daily_facts WHERE customer_id = $customer_id)"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto" }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Critical issues (open)",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 8 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
      "targets": [
        {
          "refId": "A",
          "format": 1,
          "queryType": "sql",
          "rawSql": "SELECT sum(metric_value) AS value\nFROM ptt.seo_daily_facts\nWHERE metric_name = 'critical_issues_open'\n  AND customer_id = $customer_id\n  AND fact_date = (SELECT max(fact_date) FROM ptt.seo_daily_facts WHERE customer_id = $customer_id)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto" }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "AEO coverage %",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
      "targets": [
        {
          "refId": "A",
          "format": 1,
          "queryType": "sql",
          "rawSql": "SELECT\n  fact_date AS time,\n  avg(metric_value) AS coverage_pct\nFROM ptt.seo_daily_facts\nWHERE metric_name = 'aeo_coverage_pct'\n  AND customer_id = $customer_id\n  AND fact_date >= today() - toInt32($days)\nGROUP BY fact_date\nORDER BY fact_date"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent", "min": 0, "max": 100, "custom": { "drawStyle": "line", "lineWidth": 2 } },
        "overrides": []
      }
    }
  ],
  "refresh": "30m",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["seo", "aeo", "ptt", "gate-d"],
  "templating": {
    "list": [
      {
        "name": "customer_id",
        "type": "query",
        "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
        "query": "SELECT DISTINCT customer_id FROM ptt.seo_daily_facts ORDER BY customer_id",
        "refresh": 1,
        "includeAll": false,
        "multi": false,
        "current": { "selected": true, "text": "1", "value": "1" }
      },
      {
        "name": "days",
        "type": "custom",
        "query": "7,14,28,90",
        "options": [
          { "selected": false, "text": "7", "value": "7" },
          { "selected": true, "text": "28", "value": "28" },
          { "selected": false, "text": "90", "value": "90" }
        ],
        "current": { "selected": true, "text": "28", "value": "28" }
      }
    ]
  },
  "time": { "from": "now-28d", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "PTT SEO/AEO Ops",
  "uid": "ptt-seo-ops",
  "version": 1,
  "weekStart": ""
}
