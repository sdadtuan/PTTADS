{
  "__inputs": [
    {
      "name": "DS_CLICKHOUSE",
      "label": "ClickHouse",
      "description": "grafana-clickhouse-datasource",
      "type": "datasource",
      "pluginId": "grafana-clickhouse-datasource",
      "pluginName": "ClickHouse"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "9.0.0" },
    { "type": "datasource", "id": "grafana-clickhouse-datasource", "name": "ClickHouse", "version": "4.0.0" }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Emails sent",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
      "targets": [
        {
          "refId": "A",
          "format": 1,
          "queryType": "sql",
          "rawSql": "SELECT\n  fact_date AS time,\n  sum(metric_value) AS sent\nFROM ptt.email_daily_facts\nWHERE metric_name = 'emails_sent'\n  AND client_id = toUUID('$client_id')\n  AND fact_date >= today() - toInt32($days)\nGROUP BY fact_date\nORDER BY fact_date"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 8 } },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Opens / clicks",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
      "targets": [
        {
          "refId": "A",
          "format": 1,
          "queryType": "sql",
          "rawSql": "SELECT\n  fact_date AS time,\n  sumIf(metric_value, metric_name = 'opens') AS opens,\n  sumIf(metric_value, metric_name = 'clicks') AS clicks\nFROM ptt.email_daily_facts\nWHERE client_id = toUUID('$client_id')\n  AND fact_date >= today() - toInt32($days)\n  AND metric_name IN ('opens', 'clicks')\nGROUP BY fact_date\nORDER BY fact_date"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 8 } },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Revenue attributed (28d proxy)",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 8 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
      "targets": [
        {
          "refId": "A",
          "format": 1,
          "queryType": "sql",
          "rawSql": "SELECT sum(metric_value) AS value\nFROM ptt.email_daily_facts\nWHERE metric_name = 'revenue_attrib'\n  AND client_id = toUUID('$client_id')\n  AND fact_date = (SELECT max(fact_date) FROM ptt.email_daily_facts WHERE client_id = toUUID('$client_id'))"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto" }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Complaint rate % (daily)",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 8 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
      "targets": [
        {
          "refId": "A",
          "format": 1,
          "queryType": "sql",
          "rawSql": "SELECT if(sent_count > 0, 100.0 * complaint_count / sent_count, 0) AS value\nFROM ptt.email_deliverability_daily\nWHERE client_id = toUUID('$client_id')\n  AND metric_date = (SELECT max(metric_date) FROM ptt.email_deliverability_daily WHERE client_id = toUUID('$client_id'))\nLIMIT 1"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent" }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto" }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Bounces vs complaints",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
      "targets": [
        {
          "refId": "A",
          "format": 1,
          "queryType": "sql",
          "rawSql": "SELECT\n  metric_date AS time,\n  sum(bounce_hard + bounce_soft) AS bounces,\n  sum(complaint_count) AS complaints\nFROM ptt.email_deliverability_daily\nWHERE client_id = toUUID('$client_id')\n  AND metric_date >= today() - toInt32($days)\nGROUP BY metric_date\nORDER BY metric_date"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 8 } },
        "overrides": []
      }
    }
  ],
  "refresh": "5m",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["ptt", "email", "ops"],
  "templating": {
    "list": [
      {
        "name": "client_id",
        "type": "textbox",
        "label": "Client UUID",
        "query": "",
        "current": { "text": "00000000-0000-0000-0000-000000000001", "value": "00000000-0000-0000-0000-000000000001" }
      },
      {
        "name": "days",
        "type": "custom",
        "label": "Days",
        "query": "7,28,90",
        "current": { "text": "28", "value": "28" },
        "options": [
          { "text": "7", "value": "7" },
          { "text": "28", "value": "28", "selected": true },
          { "text": "90", "value": "90" }
        ]
      }
    ]
  },
  "time": { "from": "now-30d", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "PTT Email Ops",
  "uid": "ptt-email-ops",
  "version": 1
}
