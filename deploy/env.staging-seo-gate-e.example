# Staging — Gate E (OKR, crawl connector, rank live) + CMS auto-publish pilot
# Merge vào /var/www/ptt/.env:
#   bash scripts/staging_seo_gate_e_deploy.sh  (remote merge)
# Hoặc thủ công:
#   grep -v '^#' deploy/env.staging-seo-gate-e.example >> .env

# Gate E cron jobs (weekly bundle gate-e)
PTT_CRAWL_CONNECTOR_ENABLED=1
PTT_RANK_LIVE_ENABLED=1
PTT_SERP_PROVIDER=stub

# CMS webhook pilot — auto-publish khi content → published
PTT_SEO_ENTERPRISE_ENABLED=1
PTT_SEO_CMS_AUTO_PUBLISH=1
PTT_SEO_CMS_WEBHOOK_SECRET=change-me-staging-cms-pilot
PTT_FLASK_MONOLITH_URL=https://staging.pttads.vn
PTT_SEO_CMS_PILOT_WEBHOOK_URL=https://staging.pttads.vn/api/v1/seo/internal/cms-webhook/receive
