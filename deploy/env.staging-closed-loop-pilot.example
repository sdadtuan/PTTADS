# Staging closed-loop pilot — 1 client (P0 #4)
# source before ./scripts/staging_closed_loop_pilot.sh --sync

export DATABASE_URL=postgresql://ptt:ptt_dev@127.0.0.1:5432/ptt_agency
export PTT_SQLITE_PATH=/var/www/ptt/ptt.db
export PTT_TOKEN_VAULT_KEY=                          # required for token seed

# Pilot client
export CLIENT_CODE=DEMO

# Meta account seed (./scripts/seed_meta_channel_account.py)
# META_AD_ACCOUNT_ID=act_1234567890
# META_ACCESS_TOKEN=EAAx...
# META_PIXEL_ID=123456789012345
# TOKEN_EXPIRES=2026-12-31

# Insights sync (stub OK for staging without Graph)
export PTT_META_INSIGHTS_SYNC=1
export PTT_META_INSIGHTS_STUB=1

# Hub map: crm_campaigns.agency_client_id + Meta ID stub_campaign_1 (stub) or real campaign ID
# ./scripts/sync_hub_campaign_map.sh

# Optional global pixel fallback
# PTT_META_PIXEL_ID=123456789012345
