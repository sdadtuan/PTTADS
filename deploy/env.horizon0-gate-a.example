# Horizon 0 — Gate A SEO + Email prod pilot (local/staging/VPS)
# source deploy/env.horizon0-gate-a.example

DATABASE_URL=postgresql://ptt:ptt_dev@127.0.0.1:5432/ptt_agency
PTT_ARTIFACTS_DIR=.local-dev
OPS_E2E_API_URL=http://127.0.0.1:3000
PTT_CRM_API_AUTH_DISABLED=1

# SEO Gate A
SEO_AEO_DB=pg
PTT_SEO_GOVERNANCE_ENABLED=1
PTT_PORTAL_SEO_ENABLED=0
PTT_SEO_EXPERIMENTS_ENABLED=0
PHASE5_EXPECT_GOVERNANCE=1
PHASE5_EXPECT_PORTAL=0
PHASE5_EXPECT_EXPERIMENTS=0
PHASE5_SKIP_PORTAL_SIGNOFF=1

# Email Gate A (real send pilot — set on VPS only)
PTT_EMAIL_ENABLED=1
PTT_EMAIL_SEND_ENABLED=1
PTT_EMAIL_JOURNEYS_ENABLED=0
PTT_EMAIL_PORTAL_ENABLED=1
PTT_EMAIL_ESP_DRY_RUN=1
EM5_EXPECT_EMAIL_ENABLED=1
EM5_EXPECT_SEND_ENABLED=1
EM5_EXPECT_PORTAL_ENABLED=1
EM5_EXPECT_ESP_DRY_RUN=1
EM5_INCLUDE_WAVE_GATES=1
EM5_SKIP_BUILD=1
export EM5_SKIP_NEST_SMOKE=1

# Delivery admin partial Flask retirement
PTT_FLASK_SEO_ADMIN_RETIRED=1
PTT_FLASK_EMAIL_ADMIN_RETIRED=1
PHASE5DA_SKIP_BUILD=1

# Soak (7 days) — staging bootstrap OR prod cron
PTT_PHASE5_SOAK_DAYS=7
PTT_EM5_SOAK_DAYS=7
EM5_SKIP_SOAK=0
PHASE5_SKIP_SOAK=0
# Staging only — synthesize 7d soak rows:
# HORIZON0_BOOTSTRAP_SOAK=1

# Pilot case studies: client_uuid:customer_id:Label
# HORIZON0_PILOT_CLIENTS=00000000-0000-0000-0000-000000000001:42:Pilot Client A
HORIZON0_METRICS_DAYS=28
