# Meta Enterprise B11 — Advanced (z-score, forecast, multi-pixel, snapshot)
# Requires B8 DDL v4 + B10 intelligence; apply DDL v7 for meta_pixels tables.

# Statistical anomaly (z-score 14d) — GET /meta/anomalies?mode=stat
PTT_META_ANOMALY_STAT_ENABLED=0
NEXT_PUBLIC_PTT_META_ANOMALY_STAT_ENABLED=0
PTT_META_ANOMALY_STAT_WINDOW_DAYS=14
PTT_META_ANOMALY_ZSCORE_THRESHOLD=2.0

# CPL/spend forecast — GET /meta/forecast
PTT_META_FORECAST_ENABLED=0
NEXT_PUBLIC_PTT_META_FORECAST_ENABLED=0
PTT_META_FORECAST_HISTORY_DAYS=14
PTT_META_FORECAST_PROJECTION_DAYS=7

# Multi-pixel CRUD + CAPI primary routing
PTT_META_PIXELS_ENABLED=0
NEXT_PUBLIC_PTT_META_PIXELS_ENABLED=0

# Weekly intelligence snapshot gzip + owner-weekly digest hook
PTT_META_INTEL_SNAPSHOT_ENABLED=0

# B10 flags (keep off until pilot)
PTT_META_ANOMALY_ENABLED=0
PTT_META_ROAS_ENABLED=0
NEXT_PUBLIC_PTT_META_ANOMALY_ENABLED=0
NEXT_PUBLIC_PTT_META_ROAS_ENABLED=0

# Apply before enabling pixels/snapshot:
# ./scripts/apply_pg_ddl_v7_meta_advanced.sh
