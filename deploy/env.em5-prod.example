# EM-5 Email Marketing — production pilot env (Gate A)
# source before staged cutover on VPS/staging

# Core
PTT_EMAIL_ENABLED=1
PTT_EMAIL_SEND_ENABLED=1
PTT_EMAIL_DB=pg
DATABASE_URL=postgresql://ptt:CHANGE_ME@127.0.0.1:5432/ptt_agency

# Staged pilot — enable one layer at a time
PTT_EMAIL_JOURNEYS_ENABLED=0
PTT_EMAIL_PORTAL_ENABLED=0
PTT_EMAIL_DELIVERABILITY_ALERTS=1

# Nest staff + portal auth (prod: disable stubs)
PTT_CRM_API_AUTH_DISABLED=0
PTT_STAFF_STUB_USERS=
PTT_PORTAL_STUB_USERS=

# Portal JWT (min 32 chars)
PTT_PORTAL_JWT_SECRET=CHANGE_ME-portal-jwt-min-32-chars

# Sending limits (global defaults; per-workspace overrides in PG)
PTT_EMAIL_DEFAULT_DAILY_CAP=50000
PTT_EMAIL_FREQUENCY_CAP_7D=5

# ESP — staging pilot starts dry-run; prod send uses deploy/env.em5-prod-send.example
# PTT_EMAIL_ESP_DRY_RUN=1
# EMAIL_ESP_PROVIDER=sendgrid
# SENDGRID_API_KEY=

# BI (Phase 3+ — optional at pilot)
PTT_EMAIL_CLICKHOUSE_EXPORT=0
CLICKHOUSE_URL=

# Gate expectations (match staged cutover step)
EM5_INCLUDE_WAVE_GATES=1
EM5_EXPECT_EMAIL_ENABLED=1
EM5_EXPECT_SEND_ENABLED=1
EM5_EXPECT_JOURNEYS_ENABLED=0
EM5_EXPECT_PORTAL_ENABLED=0

# Soak (enable after ≥7 days staging)
# PTT_EM5_SOAK_LOG=/var/www/ptt/.local-dev/em5-soak-evidence.jsonl
# EM5_SKIP_SOAK=0

# Run gate:
#   ./scripts/phase5_email_prod_pilot_gate.sh
# Daily soak cron:
#   ./scripts/phase5_email_soak_record.sh
