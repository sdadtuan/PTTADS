[Unit]
Description=PTT — Horizon 1 Meta Ads daily soak record (oneshot)
After=network.target postgresql.service

[Service]
Type=oneshot
User=deploy
Group=www-data
Environment=PTT_APP_DIR=/var/www/ptt
EnvironmentFile=-/var/www/ptt/.env
ExecStart=/var/www/ptt/scripts/horizon1_meta_ads_soak_record.sh

[Install]
WantedBy=multi-user.target
