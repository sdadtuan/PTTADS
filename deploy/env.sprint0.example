# Sprint 0 — Phase 2.1 bridge (W5 + AUTH + CAPI pilot)
# source before Nest / gate scripts

export DATABASE_URL=postgresql://ptt:ptt_dev@127.0.0.1:5432/ptt_agency
export PTT_SQLITE_PATH=/var/www/ptt/ptt.db
export PTT_NEST_LEADS_URL=http://127.0.0.1:3000

# W5 — prod POST create (ids from crm_leads_prod_id_seq, not >= 900M)
export PTT_LEADS_WRITE_ENABLED=1
export PTT_LEADS_CREATE_ID_MODE=prod
export PTT_CRM_API_AUTH_DISABLED=0
