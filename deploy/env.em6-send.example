# EM-6 Send Platform — env template
# Copy to .env / VPS secrets alongside EM-5 pilot vars

# Core send
PTT_EMAIL_SEND_ENABLED=1
PTT_EMAIL_ESP_DRY_RUN=0

# ESP credentials (global fallback; per-client via client_channel_accounts channel=email)
SENDGRID_API_KEY=
# SENDGRID_WEBHOOK_VERIFICATION_KEY=

# Worker / jobs
PTT_JOBS_ENABLED=1
PTT_WEBHOOK_V1_ENQUEUE=1

# Nest native email webhooks
PTT_WEBHOOKS_NEST_EMAIL=1
PTT_EMAIL_WEBHOOK_VERIFY=0

# Send tuning
PTT_EMAIL_SEND_BATCH_SIZE=100

# Temporal (optional — fallback direct enqueue when unset)
# PTT_TEMPORAL_ADDRESS=127.0.0.1:7233
# PTT_TEMPORAL_NAMESPACE=default
# PTT_TEMPORAL_TASK_QUEUE=ptt-agency
