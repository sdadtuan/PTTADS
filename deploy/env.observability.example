# Observability — Sentry + structured JSON logs (P0-09)
# Copy vars vào .env (Flask + worker + Nest)

# --- Sentry (optional — no-op khi unset) ---
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
# SENTRY_RELEASE=pttads@git-sha
# SENTRY_TRACES_SAMPLE_RATE=0.05

# --- Structured JSON access logs ---
# Auto ON khi SENTRY_ENVIRONMENT=production|staging
# Dev local: để trống hoặc PTT_JSON_LOGS=0 (plain text)
PTT_JSON_LOGS=1

# --- Nest CRM API ---
# CRM_API_PORT=3000
# (cùng SENTRY_DSN / PTT_JSON_LOGS như Flask)

# Dashboards: docs/runbooks/sentry-phase2-dashboards.md
