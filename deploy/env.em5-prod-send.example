# EM-5 Email Marketing — production send (real ESP, no dry-run)
# Copy to VPS .env after workspace + domain verify on staging
# source deploy/env.em5-prod-send.example with real secrets

# Core — send for real
PTT_EMAIL_ENABLED=1
PTT_EMAIL_SEND_ENABLED=1
PTT_EMAIL_ESP_DRY_RUN=0
PTT_EMAIL_DB=pg
DATABASE_URL=postgresql://ptt:CHANGE_ME@127.0.0.1:5432/ptt_agency

# ESP (per-client creds also in client_channel_accounts / workspace)
EMAIL_ESP_PROVIDER=sendgrid
SENDGRID_API_KEY=SG.CHANGE_ME
# MAILGUN_API_KEY=
# MAILGUN_DOMAIN=

# Staged pilot layers
PTT_EMAIL_JOURNEYS_ENABLED=0
PTT_EMAIL_PORTAL_ENABLED=1
PTT_EMAIL_DELIVERABILITY_ALERTS=1
PTT_EMAIL_WEBHOOK_VERIFY=1
SENDGRID_WEBHOOK_VERIFICATION_KEY=CHANGE_ME

# Auth — no stubs in prod
PTT_CRM_API_AUTH_DISABLED=0
PTT_STAFF_STUB_USERS=
PTT_PORTAL_STUB_USERS=
PTT_PORTAL_JWT_SECRET=CHANGE_ME-portal-jwt-min-32-chars

# Limits
PTT_EMAIL_DEFAULT_DAILY_CAP=50000
PTT_EMAIL_FREQUENCY_CAP_7D=5
PTT_EMAIL_SEND_BATCH_SIZE=100

# Gate parity (real send pilot)
EM5_INCLUDE_WAVE_GATES=1
EM5_EXPECT_EMAIL_ENABLED=1
EM5_EXPECT_SEND_ENABLED=1
EM5_EXPECT_ESP_DRY_RUN=0
EM5_EXPECT_JOURNEYS_ENABLED=0
EM5_EXPECT_PORTAL_ENABLED=1

# Soak ≥7 days before cutover sign-off
PTT_EM5_SOAK_LOG=/var/www/ptt/.local-dev/em5-soak-evidence.jsonl
EM5_SKIP_SOAK=0
PTT_EM5_SOAK_DAYS=7

# Cron (systemd timers — enable after deploy):
#   ptt-email-campaign-schedule.timer  (every 1 min)
#   ptt-email-journey.timer            (every 1 min, when journeys enabled)
#   ptt-email-soak.timer               (daily health snapshot)

# RBAC prod:
#   python3 scripts/seed_staff_email_mkt_permissions.py

# Daily soak:
#   ./scripts/phase5_email_soak_record.sh

# Gate:
#   ./scripts/phase5_email_prod_pilot_gate.sh
