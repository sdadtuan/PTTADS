[Unit]
Description=PTT — email journey enroll scan + tick (oneshot)
After=network.target postgresql.service ptt-worker.service
Wants=ptt-worker.service

[Service]
Type=oneshot
User=deploy
Group=www-data
Environment=PTT_APP_DIR=/var/www/ptt
EnvironmentFile=-/var/www/ptt/.env
ExecStart=/var/www/ptt/scripts/email_journey_cron.sh

[Install]
WantedBy=multi-user.target
