[Unit]
Description=PTT — EM-5 email marketing daily soak record (oneshot)
After=network.target postgresql.service

[Service]
Type=oneshot
User=deploy
Group=www-data
Environment=PTT_APP_DIR=/var/www/ptt
EnvironmentFile=-/var/www/ptt/.env
ExecStart=/var/www/ptt/scripts/phase5_email_soak_record.sh

[Install]
WantedBy=multi-user.target
