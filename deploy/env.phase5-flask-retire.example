# Phase 5 — Flask monolith retirement (stop ptt.service)
# Prerequisites: Phase 2 agency prod, Phase 3 portal UAT, Phase 4 readonly soak ≥14d
#
# Staging gate:
#   set -a && source deploy/env.phase5-flask-retire.example && set +a
#   ./scripts/staging_phase5_gate_pack.sh
#
# Prod cutover (VPS):
#   set -a && source deploy/env.phase5-flask-retire.example && set +a
#   # edit secrets (DATABASE_URL, JWT, internal keys)
#   sudo -E ./scripts/close_flask_retirement.sh          # dry-run
#   sudo -E APPLY=1 ./scripts/close_flask_retirement.sh  # stop ptt.service

export DATABASE_URL="${DATABASE_URL:-postgresql://ptt:CHANGE_ME@127.0.0.1:5432/ptt_agency}"
export PTT_SQLITE_PATH="${PTT_SQLITE_PATH:-/var/www/ptt/ptt.db}"

# ── Phase 2/3 base (must be prod-stable before retire) ──
export PTT_LEADS_WRITE_SOURCE=pg
export PTT_LEADS_READ_SOURCE=pg
export PTT_LEAD_SHADOW_SYNC=0
export PTT_LEAD_INGEST_RULES_SOURCE=pg
export PTT_LEADS_WRITE_UPSTREAM=nest
export PTT_NEST_LEADS_URL=http://127.0.0.1:3000
export PTT_AGENCY_OPS_UPSTREAM=ops-web
export PTT_OPS_WEB_URL=https://rs.pttads.vn

# ── Webhooks — Nest only (no Flask fallback) ──
export PTT_JOBS_ENABLED=1
export PTT_WEBHOOK_V1_ENQUEUE=1
export PTT_WEBHOOKS_NEST_ENABLED=1
export PTT_WEBHOOKS_NEST_META=1
export PTT_WEBHOOKS_NEST_ZALO=1
export PTT_WEBHOOKS_NEST_GOOGLE=1
export PTT_WEBHOOKS_FLASK_FALLBACK=0
export CRM_FACEBOOK_BACKGROUND_IN_GUNICORN=0

# ── Portal SEO native PG ──
export PTT_PORTAL_SEO_ENABLED=1
export PTT_SEO_GOVERNANCE_ENABLED=1

# ── Phase 5 Flask retire ──
export PTT_FLASK_MONOLITH_MODE=retired
export PHASE5_EXPECT_FLASK_MODE=retired

# SEO Phase 5 flags (governance on prod; experiments optional)
export PTT_SEO_EXPERIMENTS_ENABLED=0
export PHASE5_EXPECT_GOVERNANCE=1
export PHASE5_EXPECT_PORTAL=1
export PHASE5_EXPECT_EXPERIMENTS=0
export PHASE5_SKIP_SOAK=1
export PHASE5_SKIP_PRIOR_GATES=0

# ── Services (keep running after ptt.service stop) ──
# ptt-crm-api, ptt-worker, ptt-fb-autosync, ptt-temporal-worker, ops-web, portal-web

export PTT_ARTIFACTS_DIR=.local-dev
