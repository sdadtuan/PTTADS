# EM-9 / Wave 4 — prod pilot after Waves 1–3b (Gate A operational)
# Cumulative on env.em8-wave3b.example + env.em5-prod.example

# Core platform
PTT_EMAIL_ENABLED=1
PTT_EMAIL_SEND_ENABLED=1
PTT_EMAIL_JOURNEYS_ENABLED=1
PTT_EMAIL_PORTAL_ENABLED=1
PTT_EMAIL_DB=pg
DATABASE_URL=postgresql://ptt:CHANGE_ME@127.0.0.1:5432/ptt_agency

# Send platform (Wave 1)
PTT_JOBS_ENABLED=1
PTT_WEBHOOK_V1_ENQUEUE=1
PTT_WEBHOOKS_NEST_EMAIL=1
PTT_EMAIL_ESP_DRY_RUN=0
PTT_EMAIL_WEBHOOK_VERIFY=1

# Measurement (Wave 2)
PTT_EMAIL_CLICKHOUSE_EXPORT=0
PTT_EMAIL_DELIVERABILITY_ALERTS=1

# Ops-web UX flags (Wave 3/3b)
NEXT_PUBLIC_PTT_EMAIL_ENABLED=1
NEXT_PUBLIC_PTT_EMAIL_SEND_ENABLED=1
NEXT_PUBLIC_PTT_EMAIL_JOURNEYS_ENABLED=1

# Auth (prod: disable stubs)
PTT_CRM_API_AUTH_DISABLED=0
PTT_STAFF_STUB_USERS=
PTT_PORTAL_STUB_USERS=
PTT_PORTAL_JWT_SECRET=CHANGE_ME-portal-jwt-min-32-chars

# Gate expectations
EM5_INCLUDE_WAVE_GATES=1
EM5_EXPECT_EMAIL_ENABLED=1
EM5_EXPECT_SEND_ENABLED=1
EM5_EXPECT_JOURNEYS_ENABLED=1
EM5_EXPECT_PORTAL_ENABLED=1

# Soak (enable after ≥7 days staging)
# PTT_EM5_SOAK_LOG=/var/www/ptt/.local-dev/em5-soak-evidence.jsonl
# EM5_SKIP_SOAK=0
# EM5_REQUIRE_SIGNOFF=1

# Run Wave 4 gate:
#   ./scripts/phase9_email_wave4_gate.sh --refresh-all
# Refresh waves only (EM-6..EM-8b):
#   ./scripts/phase9_email_wave4_gate.sh --refresh-wave
# Full regression:
#   ./scripts/email_mkt_full_regression_gate.sh
